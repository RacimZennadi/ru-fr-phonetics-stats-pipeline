# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# DVC
.dvc/cache/
.dvc/tmp/

# Raw audio and heavy binary outputs
*.wav
*.npz
*.pt
*.bin

# Corpus folder (never commit raw data)
ru-fr_interference/

# Processed data: ignore everything EXCEPT the key CSVs
data/processed/*
!data/processed/.gitkeep
!data/processed/phoneme_tokens.csv
!data/processed/features_acoustic.csv
!data/processed/features_acoustic_norm.csv

# Interim data
data/interim/*
!data/interim/.gitkeep

# Results (regenerated by pipeline)
results/figures/*
!results/figures/.gitkeep
results/tables/*
!results/tables/.gitkeep

# Local writing artifacts
final_report.md
report/report.txt
report/report - Copy.txt
report/report_fact_check.md
report/report_revision_blueprint.md
notebooks/
src/archive/

